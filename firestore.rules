rules_version = '2';
// Update 2

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'level', 'xp', 'streak', 'lastActive', 'fluencyScore', 'wordsLearned', 'speakingTimeMinutes'])
        && data.uid == request.auth.uid
        && data.level is string && data.level.size() <= 5
        && data.xp is number
        && data.streak is number
        && data.lastActive is string
        && data.fluencyScore is number
        && data.wordsLearned is number
        && data.speakingTimeMinutes is number;
    }

    function isValidVocabWord(data) {
      return data.keys().hasAll(['uid', 'word', 'meaning', 'mastery', 'lastReviewed'])
        && data.uid == request.auth.uid
        && data.word is string && data.word.size() <= 100
        && data.meaning is string && data.meaning.size() <= 500
        && data.mastery is number
        && data.lastReviewed is string;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && isValidId(userId) && userId == request.auth.uid && isValidUserProfile(incoming());
      allow update: if isSignedIn() && userId == request.auth.uid && isValidUserProfile(incoming()) 
        && incoming().uid == existing().uid;
    }

    match /vocabulary/{wordId} {
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && isValidId(wordId) && isValidVocabWord(incoming()) && incoming().uid == request.auth.uid;
      allow update: if isSignedIn() && existing().uid == request.auth.uid && isValidVocabWord(incoming()) && incoming().uid == existing().uid;
      allow delete: if isSignedIn() && existing().uid == request.auth.uid;
    }
  }
}
